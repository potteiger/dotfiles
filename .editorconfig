# My go to editorconfig
root=true

# Unix newlines, blank newline at end because that is correct.
[*]
end_of_line=lf
insert_final_newline=true

# UTF-8. Only sensible move.
charset=utf-8

# Actual tabs, 8 columns wide.
indent_style=tab
tab_width=8

# Self-explanatory.
trim_trailing_whitespace=true

# 80-characters wide
max_line_length=80

